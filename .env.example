# Tradeer Configuration Environment Variables Template
# Copy this file to .env and configure the credentials

# AI RESEARCHER SETTINGS (OpenRouter API credentials)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# BINANCE EXCHANGE CONFIGURATION
BINANCE_API_KEY=
BINANCE_SECRET=

# TRADING BOT POLICY
# If set to true, trades are mocked locally. Set to false to execute live CCXT Binance orders.
PAPER_TRADING=true

# RISK PARAMETERS
# Maximum allowed dollar drawdown limit for a single strategy before deactivation and pool pruning
MAX_STRATEGY_DRAWDOWN=150.0

# API DASHBOARD AUTHENTICATION
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin
